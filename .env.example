# =============================================================================
# Ollama Local - Intel Arc GPU Optimized Environment Configuration
# Copy this file to .env and modify values as needed for your system
# =============================================================================

# Container Configuration
CONTAINER_NAME=ollama-arc-optimized
WEBUI_CONTAINER_NAME=ollama-webui-enhanced
IMAGE_NAME=ollama-ubuntu:24.04

# GPU Device Configuration (adjust for your system)
GPU_CARD_DEVICE=/dev/dri/card1
GPU_RENDER_DEVICE=/dev/dri/renderD129
DRI_PRIME=1

# Intel Arc GPU Core Settings
INTEL_GPU=1
OLLAMA_INTEL_GPU=true
DEVICE=Arc
INTEL_DEVICE_TARGET=arc
OLLAMA_GPU_DEVICE=/dev/dri/renderD129

# Level Zero and OneAPI Configuration
ONEAPI_DEVICE_SELECTOR=level_zero:0
SYCL_DEVICE_FILTER=level_zero:gpu
ZES_ENABLE_SYSMAN=1
ZE_ENABLE_PCI_ID_DEVICE_ORDER=1
ZE_FLAT_DEVICE_HIERARCHY=COMPOSITE
ZE_ENABLE_VALIDATION_LAYER=0
ZE_ENABLE_PARAMETER_VALIDATION=0

# SYCL Performance Optimizations
SYCL_CACHE_PERSISTENT=1
SYCL_CACHE_DIR=/tmp/sycl_cache
SYCL_PI_LEVEL_ZERO_USE_IMMEDIATE_COMMANDLISTS=1
SYCL_PI_LEVEL_ZERO_DEVICE_SCOPE_EVENTS=1
SYCL_PI_LEVEL_ZERO_USE_COPY_ENGINE=1

# Intel Compute Runtime Optimizations
INTEL_COMPUTE_RUNTIME_OCL_DEBUG=0
INTEL_COMPUTE_RUNTIME_L0_DEBUG=0
INTEL_COMPUTE_RUNTIME_ENABLE_KERNEL_DEBUG=0
NEO_DISABLE_MITIGATIONS=1
NEO_ENABLE_INDIRECT_ACCESS_DETECTION=0

# OpenCL Optimizations
CL_CONFIG_CPU_FORCE_PRIVATE_MEM_SIZE=16MB
CL_CONFIG_USE_VECTORIZER=true

# Ollama Server Configuration
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_ORIGINS=*
OLLAMA_PORT=11434
OLLAMA_GPU_LAYERS=999
OLLAMA_NUM_PARALLEL=2
OLLAMA_CONTEXT_LENGTH=16384
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_KEEP_ALIVE=5m
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q4_0
OLLAMA_GPU_OVERHEAD=2048
OLLAMA_MAX_VRAM=10000000000
OLLAMA_RUNNER_TIMEOUT=300s
OLLAMA_GPU_MEMORY_RECLAIM=true

# IPEX-LLM Optimizations
IPEX_LLM_LOW_MEM=1
IPEX_LLM_NUM_CTX=16384
IPEX_LLM_FORCE_GPU=1
IPEX_LLM_GPU_MEMORY_LIMIT=10GB

# Web UI Configuration
WEBUI_PORT=3000
WEBUI_SECRET_KEY=your-secret-key-here
WEBUI_AUTH=false
OLLAMA_BASE_URL=http://ollama-arc-optimized:11434

# Resource Limits (adjust based on your system)
OLLAMA_MEMORY_LIMIT=20G
OLLAMA_MEMORY_RESERVATION=8G
WEBUI_MEMORY_LIMIT=4G

# Debug and Monitoring
OLLAMA_DEBUG=false
OLLAMA_VERBOSE=false
ENABLE_GPU_MONITORING=false

# Docker Network Configuration
NETWORK_NAME=ollama-network
NETWORK_SUBNET=172.20.0.0/16

# Volume Paths (relative to project root)
MODELS_PATH=./data/models
CONTEXTS_PATH=./data/contexts
SYCL_CACHE_PATH=./data/sycl_cache
WEBUI_DATA_PATH=./data/webui
CONFIG_PATH=./data/config

# Build Arguments for Dockerfile
UBUNTU_VERSION=24.04
PYTHON_VERSION=3.12
ONEAPI_VERSION=2025.2
IPEX_VERSION=2.7.0

# Security Settings
CONTAINER_USER=0:0
SECURITY_OPT=seccomp:unconfined
PRIVILEGED=false

# Logging Configuration
LOG_DRIVER=json-file
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=120s

# =============================================================================
# GPU Configuration Notes:
# =============================================================================
#
# 1. GPU Device Paths:
#    - Check your GPU devices with: ls -la /dev/dri/
#    - Common Intel Arc devices: /dev/dri/renderD128, /dev/dri/renderD129
#    - Adjust GPU_RENDER_DEVICE to match your system
#
# 2. Intel Arc GPU Models:
#    - Arc A770 (16GB): Use default settings
#    - Arc A750 (8GB): Reduce OLLAMA_MAX_VRAM to 6000000000
#    - Arc A580 (8GB): Reduce OLLAMA_MAX_VRAM to 6000000000
#    - Arc A380 (6GB): Reduce OLLAMA_MAX_VRAM to 4000000000
#
# 3. Memory Settings:
#    - OLLAMA_MEMORY_LIMIT: Container memory limit
#    - OLLAMA_GPU_LAYERS: Number of layers to offload to GPU (999 = all)
#    - IPEX_LLM_GPU_MEMORY_LIMIT: GPU memory limit for IPEX-LLM
#
# 4. Performance Tuning:
#    - OLLAMA_NUM_PARALLEL: Number of parallel requests (1-4)
#    - OLLAMA_CONTEXT_LENGTH: Token context window (2048-16384)
#    - NEO_DISABLE_MITIGATIONS: Disable security mitigations for 20% speed boost
#
# =============================================================================
