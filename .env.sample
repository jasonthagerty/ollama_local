# Ollama Arc GPU Configuration
# Copy this file to .env and modify as needed

# Container Configuration
CONTAINER_NAME=ollama-arc-server
WEBUI_CONTAINER_NAME=ollama-webui

# Network Configuration
NETWORK_NAME=ollama-network

# Port Configuration
OLLAMA_PORT=11434
WEBUI_PORT=3000

# Ollama Configuration
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_ORIGINS=*
OLLAMA_GPU_LAYERS=999
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_KEEP_ALIVE=5m
OLLAMA_DEBUG=false

# Arc GPU Configuration
DRI_PRIME=1
OLLAMA_GPU_DEVICE=/dev/dri/renderD129

# Intel GPU and IPEX-LLM Configuration
OLLAMA_INTEL_GPU=true
ZES_ENABLE_SYSMAN=1
ZE_ENABLE_PCI_ID_DEVICE_ORDER=1
ONEAPI_DEVICE_SELECTOR=level_zero:0
DEVICE=Arc
SYCL_CACHE_PERSISTENT=1
SYCL_DEVICE_FILTER=level_zero:gpu
ZE_FLAT_DEVICE_HIERARCHY=COMPOSITE
INTEL_DEVICE_TARGET=arc

# Web UI Configuration
WEBUI_SECRET_KEY=change-this-secret-key-to-something-secure
WEBUI_NAME=Ollama Arc GPU
DISABLE_REGISTRATION=false
ENABLE_SIGNUP=true
ENABLE_LOGIN_FORM=true

# Resource Limits
MEMORY_LIMIT=16g
SHARED_MEMORY_SIZE=8g

# Data Paths (relative to project root)
DATA_PATH=./data
MODELS_PATH=./data/models
CONFIG_PATH=./data/config
WEBUI_DATA_PATH=./data/webui

# Advanced Intel GPU Configuration
INTEL_GPU=1
PATH=/llm/bin:/llm/ollama:/opt/ipex-llm-env/bin:/usr/local/bin:/usr/bin:/bin
LD_LIBRARY_PATH=/opt/intel/oneapi/compiler/latest/linux/lib:/opt/intel/oneapi/compiler/latest/linux/lib/x64
