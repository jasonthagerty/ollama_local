# Ollama + Intel Arc GPU Configuration
# Copy to .env and adjust for your system.

# =============================================================================
# CONTAINER
# =============================================================================
CONTAINER_NAME=ollama-arc-sycl

# =============================================================================
# GPU DEVICE PATHS
# =============================================================================
# Check with: ls -la /dev/dri/
# Arc A770 is typically card1 / renderD129 on systems with integrated GPU on card0
GPU_CARD_DEVICE=/dev/dri/card1
GPU_RENDER_DEVICE=/dev/dri/renderD129

# =============================================================================
# INTEL GPU / LEVEL ZERO SETTINGS
# =============================================================================
ONEAPI_DEVICE_SELECTOR=level_zero:0
ZES_ENABLE_SYSMAN=1
ZE_ENABLE_PCI_ID_DEVICE_ORDER=1

# =============================================================================
# VOLUME PATHS
# =============================================================================
# Path for model weight storage — use fast NVMe if available
MODELS_PATH=./data/models

# =============================================================================
# OLLAMA PERFORMANCE
# =============================================================================
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_PORT=11434
OLLAMA_CONTEXT_LENGTH=32768
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=3
OLLAMA_KEEP_ALIVE=5m
# Flash attention not supported by SYCL backend
OLLAMA_FLASH_ATTENTION=false
OLLAMA_KV_CACHE_TYPE=q8_0

# =============================================================================
# CORS
# =============================================================================
OLLAMA_ORIGINS=http://localhost:3000,http://localhost:11434
